# 우리 여행 지도 — 환경변수 예시
# 실제 값은 .env.local에 넣으세요 (.env.local은 git에 커밋되지 않습니다)
#
# Vercel에 배포한 경우, 아래 명령으로 실제 값을 자동으로 받아올 수 있어요:
#   vercel env pull .env.local

# Neon Postgres 연결 주소 (Vercel 대시보드 → Storage → Neon 연결 시 자동 생성)
DATABASE_URL=

# Vercel Blob 읽기/쓰기 토큰 (Vercel 대시보드 → Storage → Blob 스토어 연결 시 자동 생성)
# 참고: 스토어를 커스텀 접두사로 연결해 `<접두사>_READ_WRITE_TOKEN` 이름으로 등록된 경우에도
#       코드가 자동으로 찾아 사용합니다.
BLOB_READ_WRITE_TOKEN=
